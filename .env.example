# Example configuration for forks. Copy to .env and fill in your values.
# .env itself is gitignored.

# === AWS / hosting ===
# S3 bucket that serves the site (must match your CloudFront origin).
S3_BUCKET=your-bucket.example.com

# CloudFront distribution ID — used for cache invalidation after deploys.
CLOUDFRONT_DISTRIBUTION_ID=E000XXXXXXXXX

# AWS region for the Lambda + SSM parameter (CloudFront standard logs work best with US regions).
AWS_REGION=us-east-1

# === Live scores upstream ===
# Stored in SSM Parameter Store as a SecureString. The Lambda reads it at cold-start.
# DO NOT commit the actual value — `aws ssm put-parameter` it directly.
SSM_PARAMETER_NAME=/yourapp/upstream-api-key

# Football-data.org URL the Lambda hits. The default fetches WC matches with non-scheduled status.
UPSTREAM_URL=https://api.football-data.org/v4/competitions/WC/matches?status=LIVE,IN_PLAY,PAUSED,FINISHED

# === Terraform variables ===
# Pass these on `terraform apply` or put in infra/live-poller/terraform.tfvars
TF_VAR_s3_bucket=your-bucket.example.com
TF_VAR_ssm_parameter_name=/yourapp/upstream-api-key
TF_VAR_name_prefix=yourapp-live-poller
